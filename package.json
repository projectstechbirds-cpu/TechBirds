{
  "name": "techbirds-platform",
  "version": "1.0.0",
  "private": true,
  "description": "TechBirds Group monorepo — marketing site, blog, internal portal, FastAPI backend.",
  "packageManager": "npm@10.9.3",
  "workspaces": ["apps/*", "packages/*"],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --parallel --filter=@techbirds/www --filter=@techbirds/blog --filter=@techbirds/app",
    "dev:www": "turbo run dev --filter=@techbirds/www",
    "dev:blog": "turbo run dev --filter=@techbirds/blog",
    "dev:app": "turbo run dev --filter=@techbirds/app",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
