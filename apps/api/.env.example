# Copy to .env for local dev. Real secrets live only on the server.
SECRET_KEY=dev-secret-change-me
ENVIRONMENT=development
APP_VERSION=0.1.0

DATABASE_URL=postgresql+asyncpg://techbirds:techbirds@localhost:5432/techbirds
DATABASE_URL_SYNC=postgresql+psycopg://techbirds:techbirds@localhost:5432/techbirds
REDIS_URL_CACHE=redis://localhost:6379/0
REDIS_URL_CELERY=redis://localhost:6379/1
REDIS_URL_SESSIONS=redis://localhost:6379/2
REDIS_URL_RATELIMIT=redis://localhost:6379/3

COOKIE_DOMAIN=.techbirdsgroup.com
# In development set COOKIE_SECURE=false so cookies work over http://localhost.
COOKIE_SECURE=true
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=
NOREPLY_FROM=no-reply@techbirdsgroup.com
HR_FROM=hr@techbirdsgroup.com
INFO_FROM=info@techbirdsgroup.com

TURNSTILE_SECRET_KEY=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
