# TechBirds API — production environment template.
# Copy to /srv/techbirds/api/.env on the server and fill in real values.
# Never commit real secrets.

# ---- Core ---------------------------------------------------------------
ENVIRONMENT=production
SECRET_KEY=change-me-to-a-64-char-random-string
APP_VERSION=1.0.0
SENTRY_DSN=

# ---- Tokens / Cookies ---------------------------------------------------
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
COOKIE_DOMAIN=.techbirdsgroup.com
COOKIE_SECURE=true

# ---- Database / Redis ---------------------------------------------------
DATABASE_URL=postgresql+asyncpg://techbirds:STRONG_DB_PASSWORD@localhost:5432/techbirds
DATABASE_URL_SYNC=postgresql+psycopg://techbirds:STRONG_DB_PASSWORD@localhost:5432/techbirds
REDIS_URL_CACHE=redis://localhost:6379/0
REDIS_URL_CELERY=redis://localhost:6379/1
REDIS_URL_SESSIONS=redis://localhost:6379/2
REDIS_URL_RATELIMIT=redis://localhost:6379/3

# ---- CORS ---------------------------------------------------------------
# JSON-style list. Pydantic will parse it.
CORS_ORIGINS=["https://techbirdsgroup.com","https://blog.techbirdsgroup.com","https://app.techbirdsgroup.com"]

# ---- Public URLs --------------------------------------------------------
WWW_PUBLIC_URL=https://techbirdsgroup.com
BLOG_PUBLIC_URL=https://blog.techbirdsgroup.com
APP_PUBLIC_URL=https://app.techbirdsgroup.com

# ---- Email (SendGrid SMTP) ---------------------------------------------
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.real-sendgrid-api-key
NOREPLY_FROM=no-reply@techbirdsgroup.com
HR_FROM=hr@techbirdsgroup.com
INFO_FROM=info@techbirdsgroup.com
ADMIN_EMAILS=["info@techbirdsgroup.com","prudhviraju.penumatsa@techbirdsgroup.com"]
HR_EMAILS=["hr@techbirdsgroup.com"]
SUPER_ADMIN_EMAIL=prudhviraju.penumatsa@techbirdsgroup.com

# ---- Cloudflare Turnstile ----------------------------------------------
TURNSTILE_SECRET_KEY=

# ---- Cloudflare R2 (S3-compatible) -------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_PUBLIC=techbirds-public
R2_BUCKET_BLOG=techbirds-blog
R2_BUCKET_FEED=techbirds-feed
R2_BUCKET_FILES=techbirds-files
R2_BUCKET_BACKUPS=techbirds-backups
