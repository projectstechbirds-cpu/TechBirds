# ─────────────────────────────────────────────────────────────────────────────
# TechBirds Platform — environment template
# Copy to .env and fill values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Frontends (Vite) ────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8002
VITE_WWW_URL=http://localhost:5173
VITE_BLOG_URL=http://localhost:5174
VITE_APP_URL=http://localhost:5175

VITE_TURNSTILE_SITE_KEY=
VITE_PLAUSIBLE_DOMAIN=techbirdsgroup.com
VITE_SENTRY_DSN_FRONTEND=

# ─── Backend (FastAPI) ───────────────────────────────────────────────────────
ENV=development
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
COOKIE_DOMAIN=.techbirdsgroup.com
COOKIE_SECURE=false

# Postgres
DATABASE_URL=postgresql+asyncpg://techbirds:techbirds@localhost:5432/techbirds_db_dev
DATABASE_URL_SYNC=postgresql+psycopg://techbirds:techbirds@localhost:5432/techbirds_db_dev

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_URL_CELERY=redis://localhost:6379/1
REDIS_URL_SESSIONS=redis://localhost:6379/2
REDIS_URL_RATELIMIT=redis://localhost:6379/3

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,https://techbirdsgroup.com,https://www.techbirdsgroup.com,https://blog.techbirdsgroup.com,https://app.techbirdsgroup.com

# ─── Email (SendGrid + Hostinger/Zoho mailboxes) ─────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=
SENDGRID_API_KEY=

NOREPLY_FROM=TechBirds <no-reply@techbirdsgroup.com>
HR_FROM=TechBirds HR <hr@techbirdsgroup.com>
INFO_FROM=TechBirds <info@techbirdsgroup.com>

ADMIN_EMAILS=info@techbirdsgroup.com,prudhviraju.penumatsa@techbirdsgroup.com
HR_EMAILS=hr@techbirdsgroup.com
SUPER_ADMIN_EMAIL=prudhviraju.penumatsa@techbirdsgroup.com

# ─── Cloudflare ──────────────────────────────────────────────────────────────
TURNSTILE_SECRET_KEY=
CF_ACCOUNT_ID=
CF_API_TOKEN=

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BUCKET=techbirdsgroup-public
R2_BLOG_BUCKET=techbirdsgroup-blog
R2_FEED_BUCKET=techbirdsgroup-feed
R2_FILES_BUCKET=techbirdsgroup-files
R2_BACKUPS_BUCKET=techbirdsgroup-backups
R2_PUBLIC_URL=https://files.techbirdsgroup.com

# ─── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO

# ─── Calendly ────────────────────────────────────────────────────────────────
CALENDLY_LINK=https://calendly.com/techbirds/intro
